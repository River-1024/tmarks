#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Git post-merge hook
# 在 git pull 或 git merge 后自动执行

echo ""
echo "🔍 检查是否有新的数据库迁移..."
echo ""

# 检查是否有迁移文件变更
if git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -q "^migrations/[0-9]"; then
  echo "📦 检测到新的迁移文件，准备执行..."
  echo ""
  
  # 询问用户是否执行迁移
  echo "是否立即执行数据库迁移？"
  echo "  1) 是 - 本地开发环境"
  echo "  2) 是 - 生产环境"
  echo "  3) 否 - 稍后手动执行"
  echo ""
  read -p "请选择 (1/2/3): " choice
  
  case $choice in
    1)
      echo ""
      echo "🚀 执行本地迁移..."
      pnpm db:auto-migrate:local
      ;;
    2)
      echo ""
      echo "🚀 执行生产环境迁移..."
      pnpm db:auto-migrate
      ;;
    *)
      echo ""
      echo "⏭️  已跳过，请稍后手动执行："
      echo "   本地: pnpm db:auto-migrate:local"
      echo "   生产: pnpm db:auto-migrate"
      ;;
  esac
else
  echo "✅ 无新的迁移文件"
fi

echo ""
